// Flostruction — Founding Customer Landing Page
// flosmosis.com/founding
// One page. One decision. One form. No navigation. No exit links.
'use client';

import { useState, useEffect, type FormEvent } from 'react';

/* ═════════════════════════════════════════════════
   METADATA — exported from a separate layout or head component
   since this is a client component, metadata is handled via
   a companion layout.tsx in the same folder.
   ═══════════════════════════════════════════════════════════ */

/* ── F-mark SVG Logo ── */
function FMark({ size = 32 }: { size?: number }) {
  return (
    <svg width={size} height={size} viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="40" height="40" rx="8" fill="#0E1C2F" />
      <text x="10" y="29" fontFamily="IBM Plex Mono, monospace" fontWeight="700" fontSize="24" fill="#4ade80">F</text>
    </svg>
  );
}

/* ── Receipt Card ── */
function ReceiptCard() {
  return (
    <div style={{
      background: '#0E1C2F',
      border: '1px solid rgba(255,255,255,0.1)',
      borderRadius: '12px',
      padding: '28px 24px',
      maxWidth: '380px',
      width: '100%',
      fontFamily: "'IBM Plex Mono', monospace",
    }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '20px' }}>
        <span style={{ color: '#9B9890', fontSize: '0.7rem', letterSpacing: '0.1em', textTransform: 'uppercase' }}>FLOSTRUCTION Receipt</span>
        <span style={{
          background: 'rgba(74,222,128,0.12)',
          color: '#4ade80',
          fontSize: '0.65rem',
          fontWeight: 600,
          padding: '3px 10px',
          borderRadius: '20px',
          letterSpacing: '0.06em',
        }}>VERIFIED</span>
      </div>
      <div style={{ color: '#F5F3EE', fontSize: '1.1rem', fontWeight: 700, marginBottom: '20px', letterSpacing: '0.04em' }}>
        FSTR-JK5QPAVQ
      </div>
      {[
        ['Worker', 'Steve'],
        ['Site', 'Canberra Construction Site'],
        ['Date', '20 April 2026'],
        ['Clock In', '06:02 AEST'],
        ['Clock Out', '15:47 AEST'],
        ['Hours', '9.75'],
        ['Approved', '16:12 AEST'],
      ].map(([label, value]) => (
        <div key={label} style={{
          display: 'flex', justifyContent: 'space-between',
          padding: '6px 0',
          borderBottom: '1px solid rgba(255,255,255,0.04)',
        }}>
          <span style={{ color: '#6B6860', fontSize: '0.75rem' }}>{label}</span>
          <span style={{ color: '#E8E6E0', fontSize: '0.75rem', fontWeight: 500 }}>{value}</span>
        </div>
      ))}
      <div style={{ marginTop: '16px', display: 'flex', justifyContent: 'space-between' }}>
        <div>
          <div style={{ color: '#6B6860', fontSize: '0.65rem', marginBottom: '2px' }}>Chain Integrity</div>
          <div style={{ color: '#4ade80', fontSize: '0.75rem', fontWeight: 600 }}>INTACT</div>
        </div>
        <div style={{ textAlign: 'right' }}>
          <div style={{ color: '#6B6860', fontSize: '0.65rem', marginBottom: '2px' }}>WLES v1.0</div>
          <div style={{ color: '#166534', fontSize: '0.75rem', fontWeight: 600 }}>Verified</div>
        </div>
      </div>
    </div>
  );
}

/* ── Step Card ── */
function StepCard({ num, title, text, icon }: { num: string; title: string; text: string; icon: string }) {
  return (
    <div style={{ flex: 1, minWidth: '240px', textAlign: 'center', padding: '20px' }}>
      <div style={{
        width: '56px', height: '56px', borderRadius: '50%',
        background: 'rgba(14,28,47,0.08)', display: 'flex',
        alignItems: 'center', justifyContent: 'center',
        margin: '0 auto 16px', fontSize: '1.5rem',
      }}>{icon}</div>
      <div style={{
        fontFamily: "'IBM Plex Mono', monospace",
        fontSize: '2rem', fontWeight: 700, color: '#0E1C2F', marginBottom: '8px',
      }}>{num}</div>
      <div style={{
        fontFamily: "'IBM Plex Mono', monospace",
        fontSize: '1rem', fontWeight: 600, color: '#0E1C2F', marginBottom: '8px',
      }}>{title}</div>
      <div style={{
        fontFamily: "'IBM Plex Sans', sans-serif",
        fontSize: '0.85rem', color: '#6B6860', lineHeight: 1.6,
      }}>{text}</div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════════════
   MAIN PAGE COMPONENT
   ═════════════════════════════════════════════════════════════ */
export default function FoundingPage() {
  const [spotsRemaining, setSpotsRemaining] = useState<number>(20);
  const [phone, setPhone] = useState('');
  const [companyName, setCompanyName] = useState('');
  const [contactName, setContactName] = useState('');
  const [workerCount, setWorkerCount] = useState('');
  const [submitting, setSubmitting] = useState(false);
  const [submitted, setSubmitted] = useState(false);
  const [spotNumber, setSpotNumber] = useState<number>(0);
  const [error, setError] = useState('');

  useEffect(() => {
    fetch('/api/founding')
      .then(r => r.json())
      .then(d => { if (typeof d.spotsRemaining === 'number') setSpotsRemaining(d.spotsRemaining); })
      .catch(() => {});
  }, []);

  async function handleSubmit(e: FormEvent) {
    e.preventDefault();
    if (!phone.trim() || phone.trim().length < 8) {
      setError('Please enter a valid mobile number.');
      return;
    }
    setSubmitting(true);
    setError('');
    try {
      const res = await fetch('/api/founding', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: phone.trim(),
          company_name: companyName.trim() || undefined,
          contact_name: contactName.trim() || undefined,
          worker_count: workerCount ? parseInt(workerCount, 10) : undefined,
        }),
      });
      const data = await res.json();
      if (data.success) {
        setSubmitted(true);
        setSpotNumber(data.spotNumber);
        setSpotsRemaining(data.spotsRemaining);
      } else if (data.waitlist) {
        setError('All founding spots have been taken. We will add you to the waitlist.');
      } else {
        setError(data.error || 'Something went wrong. Please try again.');
      }
    } catch {
      setError('Network error. Please try again or call Lauren: 0413 573 579');
    } finally {
      setSubmitting(false);
    }
  }

  return (
    <div style={{ minHeight: '100vh', background: '#0E1C2F' }}>
      {/* ── Google Fonts ── */}
      {/* eslint-disable-next-line @next/next/no-page-custom-font */}
      <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400&display=swap"
        rel="stylesheet"
      />

      {/* ══════ HEADER ══════ */}
      <header style={{
        padding: '16px 24px',
        borderBottom: '1px solid rgba(255,255,255,0.06)',
        display: 'flex', alignItems: 'center', gap: '10px',
      }}>
        <FMark size={28} />
        <span style={{
          fontFamily: "'IBM Plex Mono', monospace",
          fontWeight: 700, fontSize: '0.9rem',
          letterSpacing: '0.08em', color: '#E8E6E0',
        }}>FLOSTRUCTION</span>
      </header>

      {/* ══════ HERO ══════ */}
      <section style={{
        padding: '80px 24px',
        maxWidth: '1200px', margin: '0 auto',
        display: 'flex', flexWrap: 'wrap' as const,
        alignItems: 'center', gap: '60px',
      }}>
        <div style={{ flex: '1 1 480px', minWidth: '300px' }}>
          <h1 style={{
            fontFamily: "'IBM Plex Mono', monospace",
            color: '#FFFFFF', fontSize: 'clamp(1.4rem, 3vw, 2rem)',
            fontWeight: 700, lineHeight: 1.3, marginBottom: '20px',
          }}>
            You know when your worker says 9 hours and your supervisor says 8?
          </h1>
          <p style={{
            fontFamily: "'IBM Plex Serif', serif",
            color: '#F5F3EE', fontSize: 'clamp(1.1rem, 2vw, 1.4rem)',
            lineHeight: 1.5, marginBottom: '20px',
          }}>
            FLOSTRUCTION records what both sides agreed.
          </p>
          <p style={{
            fontFamily: "'IBM Plex Sans', sans-serif",
            color: 'rgba(255,255,255,0.6)', fontSize: '0.95rem',
            lineHeight: 1.7, maxWidth: '520px',
          }}>
            Worker clocks in. Supervisor approves by SMS. Permanent receipt issued. Cannot be changed.
          </p>
        </div>
        <div style={{ flex: '0 1 auto' }}>
          <ReceiptCard />
        </div>
      </section>

      {/* ══════ PROOF STRIP ══════ */}
      <section style={{
        background: '#132238',
        padding: '24px',
        textAlign: 'center',
      }}>
        <p style={{
          fontFamily: "'IBM Plex Mono', monospace",
          fontSize: '0.8rem', color: '#F5F3EE',
          letterSpacing: '0.08em', maxWidth: '800px',
          margin: '0 auto', lineHeight: 1.6,
        }}>
          Running live on an active Canberra construction site since 20 April 2026. Real workers. Real shifts. Real receipts. Zero disputes.
        </p>
      </section>

      {/* ══════ HOW IT WORKS ══════ */}
      <section style={{
        background: '#F5F3EE',
        padding: '60px 24px',
      }}>
        <div style={{ maxWidth: '1000px', margin: '0 auto' }}>
          <h2 style={{
            fontFamily: "'IBM Plex Mono', monospace",
            color: '#0E1C2F', fontSize: 'clamp(1.3rem, 2.5vw, 1.8rem)',
            fontWeight: 700, textAlign: 'center', marginBottom: '48px',
          }}>
            Three steps. No training required.
          </h2>
          <div style={{
            display: 'flex', flexWrap: 'wrap' as const,
            justifyContent: 'center', gap: '20px',
          }}>
            <StepCard
              num="1"
              title="Worker clocks in"
              text="Your crew opens flosmosis.com/field on their phone. Taps Clock In. Takes five seconds."
              icon={'📱'}
            />
            <StepCard
              num="2"
              title="Supervisor approves by SMS"
              text="You get a text at end of day. Reply YES ALL. Three receipts issued. Done."
              icon={'💬'}
            />
            <StepCard
              num="3"
              title="Permanent record"
              text="Every shift gets an FSTR- receipt. SHA-256 verified. Both sides agreed. Cannot be changed."
              icon={'📋'}
            />
          </div>
        </div>
      </section>

      {/* ══════ THE FOUNDING OFFER ══════ */}
      <section style={{
        background: '#0E1C2F',
        padding: '80px 24px',
        textAlign: 'center',
      }}>
        <div style={{ maxWidth: '700px', margin: '0 auto' }}>
          <p style={{
            fontFamily: "'IBM Plex Mono', monospace",
            color: '#4ade80', fontSize: '0.75rem',
            fontVariant: 'all-small-caps' as const,
            letterSpacing: '0.2em', marginBottom: '20px',
            fontWeight: 600,
          }}>
            FLOSTRUCTION FOUNDING CUSTOMER PROGRAMME
          </p>
          <h2 style={{
            fontFamily: "'IBM Plex Mono', monospace",
            color: '#FFFFFF', fontSize: 'clamp(1.5rem, 3vw, 2.2rem)',
            fontWeight: 700, marginBottom: '40px',
          }}>
            20 spots only. First in.
          </h2>

          {[
            '60 days free',
            '$399/month — locked for 3 years',
            'Your crew live in 48 hours',
            'No credit card required',
            'No lock-in. Cancel anytime before Day 60.',
          ].map((line) => (
            <p key={line} style={{
              fontFamily: "'IBM Plex Mono', monospace",
              color: '#E8E6E0', fontSize: 'clamp(1rem, 2vw, 1.3rem)',
              fontWeight: 600, marginBottom: '12px',
            }}>{line}</p>
          ))}

          <p style={{
            fontFamily: "'IBM Plex Serif', serif",
            fontStyle: 'italic', color: '#F5F3EE',
            fontSize: '0.95rem', marginTop: '32px',
            maxWidth: '540px', margin: '32px auto 0',
            lineHeight: 1.6,
          }}>
            Companies that join after 1 July pay $499/month. Founding customers pay $399 &mdash; forever.
          </p>

          <div style={{
            marginTop: '40px',
            fontFamily: "'IBM Plex Mono', monospace",
            color: '#4ade80', fontSize: '1.2rem', fontWeight: 700,
          }}>
            {spotsRemaining > 0
              ? `${spotsRemaining} of 20 founding spots remaining`
              : 'All founding spots taken — join the waitlist'
            }
          </div>
        </div>
      </section>

      {/* ══════ SIGN-UP FORM ══════ */}
      <section style={{
        background: '#FFFFFF',
        padding: '60px 24px',
      }}>
        <div style={{ maxWidth: '540px', margin: '0 auto' }}>
          {!submitted ? (
            <>
              <h2 style={{
                fontFamily: "'IBM Plex Mono', monospace",
                color: '#0E1C2F', fontSize: 'clamp(1.3rem, 2.5vw, 1.6rem)',
                fontWeight: 700, marginBottom: '8px',
              }}>
                Secure your founding spot
              </h2>
              <p style={{
                fontFamily: "'IBM Plex Serif', serif",
                fontStyle: 'italic', color: '#6B6860',
                fontSize: '0.85rem', marginBottom: '32px',
              }}>
                Joao will call you within 24 hours to get your crew set up.
              </p>

              <form onSubmit={handleSubmit}>
                {/* Phone — required */}
                <div style={{ marginBottom: '20px' }}>
                  <label style={{
                    display: 'block', fontFamily: "'IBM Plex Mono', monospace",
                    fontSize: '0.75rem', color: '#0E1C2F',
                    fontWeight: 600, marginBottom: '6px',
                  }}>Your mobile *</label>
                  <input
                    type="tel"
                    required
                    placeholder="04XX XXX XXX"
                    value={phone}
                    onChange={(e) => setPhone(e.target.value)}
                    style={{
                      width: '100%', padding: '14px 16px',
                      border: '1px solid #E2E0DA', borderRadius: '6px',
                      fontFamily: "'IBM Plex Sans', sans-serif",
                      fontSize: '1rem', color: '#0E1C2F',
                      outline: 'none', background: '#FAFAF8',
                    }}
                  />
                </div>

                {/* Company */}
                <div style={{ marginBottom: '20px' }}>
                  <label style={{
                    display: 'block', fontFamily: "'IBM Plex Mono', monospace",
                    fontSize: '0.75rem', color: '#0E1C2F',
                    fontWeight: 600, marginBottom: '6px',
                  }}>Company name</label>
                  <input
                    type="text"
                    placeholder="Dass Labour Hire Pty Ltd"
                    value={companyName}
                    onChange={(e) => setCompanyName(e.target.value)}
                    style={{
                      width: '100%', padding: '14px 16px',
                      border: '1px solid #E2E0DA', borderRadius: '6px',
                      fontFamily: "'IBM Plex Sans', sans-serif",
                      fontSize: '1rem', color: '#0E1C2F',
                      outline: 'none', background: '#FAFAF8',
                    }}
                  />
                </div>

                {/* Name */}
                <div style={{ marginBottom: '20px' }}>
                  <label style={{
                    display: 'block', fontFamily: "'IBM Plex Mono', monospace",
                    fontSize: '0.75rem', color: '#0E1C2F',
                    fontWeight: 600, marginBottom: '6px',
                  }}>Your name</label>
                  <input
                    type="text"
                    placeholder="Mo Shaaf"
                    value={contactName}
                    onChange={(e) => setContactName(e.target.value)}
                    style={{
                      width: '100%', padding: '14px 16px',
                      border: '1px solid #E2E0DA', borderRadius: '6px',
                      fontFamily: "'IBM Plex Sans', sans-serif",
                      fontSize: '1rem', color: '#0E1C2F',
                      outline: 'none', background: '#FAFAF8',
                    }}
                  />
                </div>

                {/* Workers */}
                <div style={{ marginBottom: '28px' }}>
                  <label style={{
                    display: 'block', fontFamily: "'IBM Plex Mono', monospace",
                    fontSize: '0.75rem', color: '#0E1C2F',
                    fontWeight: 600, marginBottom: '6px',
                  }}>Workers on site</label>
                  <input
                    type="number"
                    placeholder="Approximate number"
                    value={workerCount}
                    onChange={(e) => setWorkerCount(e.target.value)}
                    style={{
                      width: '100%', padding: '14px 16px',
                      border: '1px solid #E2E0DA', borderRadius: '6px',
                      fontFamily: "'IBM Plex Sans', sans-serif",
                      fontSize: '1rem', color: '#0E1C2F',
                      outline: 'none', background: '#FAFAF8',
                    }}
                  />
                </div>

                {error && (
                  <div style={{
                    padding: '12px 16px', marginBottom: '16px',
                    background: '#FEF2F2', border: '1px solid #FECACA',
                    borderRadius: '6px', color: '#dc2626',
                    fontFamily: "'IBM Plex Sans', sans-serif",
                    fontSize: '0.85rem',
                  }}>{error}</div>
                )}

                <button
                  type="submit"
                  disabled={submitting}
                  style={{
                    width: '100%', padding: '16px',
                    background: submitting ? '#6B6860' : '#0E1C2F',
                    color: '#FFFFFF', border: 'none',
                    borderRadius: '6px', cursor: submitting ? 'wait' : 'pointer',
                    fontFamily: "'IBM Plex Mono', monospace",
                    fontSize: '0.9rem', fontWeight: 700,
                    textTransform: 'uppercase' as const,
                    letterSpacing: '0.06em',
                    transition: 'background 0.2s',
                  }}
                  onMouseOver={(e) => { if (!submitting) (e.target as HTMLElement).style.background = '#166534'; }}
                  onMouseOut={(e) => { if (!submitting) (e.target as HTMLElement).style.background = '#0E1C2F'; }}
                >
                  {submitting ? 'Submitting...' : 'Secure my founding spot →'}
                </button>
              </form>

              <p style={{
                textAlign: 'center', marginTop: '20px',
                fontFamily: "'IBM Plex Sans', sans-serif",
                fontSize: '0.8rem', color: '#6B6860',
              }}>
                Rather call? Lauren: 0413 573 579
              </p>
            </>
          ) : (
            /* ── Confirmation ── */
            <div style={{ textAlign: 'center', padding: '40px 0' }}>
              <p style={{
                fontFamily: "'IBM Plex Mono', monospace",
                color: '#0E1C2F', fontSize: '2.5rem',
                fontWeight: 700, marginBottom: '16px',
              }}>Done.</p>
              <p style={{
                fontFamily: "'IBM Plex Serif', serif",
                fontStyle: 'italic', color: '#0E1C2F',
                fontSize: '1.1rem', marginBottom: '16px',
              }}>Joao will call you within 24 hours.</p>
              <p style={{
                fontFamily: "'IBM Plex Mono', monospace",
                color: '#166534', fontSize: '1rem',
                fontWeight: 600, marginBottom: '16px',
              }}>
                You are Founding Customer #{spotNumber}.
              </p>
              <p style={{
                fontFamily: "'IBM Plex Sans', sans-serif",
                color: '#6B6860', fontSize: '0.85rem',
              }}>
                Check your messages &mdash; we will send a confirmation shortly.
              </p>
            </div>
          )}
        </div>
      </section>

      {/* ══════ COMPLIANCE ══════ */}
      <section style={{
        background: '#FFFFFF',
        padding: '0 24px 24px',
        textAlign: 'center',
      }}>
        <p style={{
          fontFamily: "'IBM Plex Mono', monospace",
          fontSize: '0.65rem', color: '#6B6860',
          maxWidth: '600px', margin: '0 auto',
          lineHeight: 1.6,
        }}>
          FLOSTRUCTION records hours worked. It does not calculate wages, award entitlements, tax, or superannuation.
        </p>
      </section>

      {/* ══════ FOOTER ══════ */}
      <footer style={{
        background: '#F5F3EE',
        borderTop: '1px solid #E2E0DA',
        padding: '20px 40px',
        display: 'flex', flexWrap: 'wrap' as const,
        justifyContent: 'space-between',
        alignItems: 'center', gap: '12px',
      }}>
        <span style={{
          fontFamily: "'IBM Plex Mono', monospace",
          fontSize: '0.55rem', color: '#6B6860',
        }}>
          FLOSMOSIS PTY LTD | flosmosis.com | lauren@flosmosis.com.au | ABN [PENDING]
        </span>
        <span style={{
          fontFamily: "'IBM Plex Mono', monospace",
          fontSize: '0.55rem', color: '#6B6860',
        }}>
          Every hour flows. Every record right.
        </span>
      </footer>
    </div>
  );
}
